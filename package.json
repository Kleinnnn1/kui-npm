{
  "name": "@kennbalino/kui",
  "version": "2.0.6",
  "description": "A minimal, dark-first React component library built with Tailwind CSS and CVA.",
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "typescript",
    "kui"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=3",
    "class-variance-authority": ">=0.7",
    "clsx": ">=2",
    "tailwind-merge": ">=2",
    "lucide-react": ">=0.400.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
